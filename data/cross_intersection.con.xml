<?xml version="1.0" encoding="UTF-8"?>
<connections>
    <!-- From North: straight to South, right to West, left to East -->
    <connection from="E_N_in" to="E_S_out" fromLane="0" toLane="0" dir="s"/>
    <connection from="E_N_in" to="E_S_out" fromLane="1" toLane="1" dir="s"/>
    <connection from="E_N_in" to="E_W_out" fromLane="0" toLane="0" dir="r"/>
    <connection from="E_N_in" to="E_E_out" fromLane="1" toLane="0" dir="l"/>
    
    <!-- From South: straight to North, right to East, left to West -->
    <connection from="E_S_in" to="E_N_out" fromLane="0" toLane="0" dir="s"/>
    <connection from="E_S_in" to="E_N_out" fromLane="1" toLane="1" dir="s"/>
    <connection from="E_S_in" to="E_E_out" fromLane="0" toLane="0" dir="r"/>
    <connection from="E_S_in" to="E_W_out" fromLane="1" toLane="0" dir="l"/>
    
    <!-- From East: straight to West, right to North, left to South -->
    <connection from="E_E_in" to="E_W_out" fromLane="0" toLane="0" dir="s"/>
    <connection from="E_E_in" to="E_W_out" fromLane="1" toLane="1" dir="s"/>
    <connection from="E_E_in" to="E_N_out" fromLane="0" toLane="0" dir="r"/>
    <connection from="E_E_in" to="E_S_out" fromLane="1" toLane="0" dir="l"/>
    
    <!-- From West: straight to East, right to South, left to North -->
    <connection from="E_W_in" to="E_E_out" fromLane="0" toLane="0" dir="s"/>
    <connection from="E_W_in" to="E_E_out" fromLane="1" toLane="1" dir="s"/>
    <connection from="E_W_in" to="E_S_out" fromLane="0" toLane="0" dir="r"/>
    <connection from="E_W_in" to="E_N_out" fromLane="1" toLane="0" dir="l"/>
</connections>
