<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <input>
        <net-file value="cross_intersection.net.xml"/>
        <route-files value="cross_intersection.rou.xml"/>
    </input>
    <time>
        <begin value="0"/>
        <end value="3600"/>
        <step-length value="1"/>
    </time>
    <output>
        <fcd-output value="fcd_output.xml"/>
    </output>
    <report>
        <verbose value="false"/>
        <no-step-log value="true"/>
    </report>
</configuration>
